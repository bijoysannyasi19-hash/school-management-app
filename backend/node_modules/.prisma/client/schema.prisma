generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Enums not supported in SQLite, using String constants instead

model User {
  id        String    @id @default(uuid())
  email     String?   @unique
  phone     String?   @unique
  password  String
  role      String    @default("STUDENT")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?

  // Relations
  profile Profile?
  student Student?
  teacher Teacher?
  parent  Parent?

  bookIssues     BookIssue[]
  drivenVehicles Vehicle[]

  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications    Notification[]

  workspacePosts     WorkspacePost[]
  doubtReplies       DoubtReply[]
  discussionThreads  DiscussionThread[]
  threadReplies      ThreadReply[]
  surveyResponses    SurveyResponse[]
  complaints         Complaint[]
  eventRegistrations EventRegistration[]
  lostFoundItems     LostFoundItem[]
  visitorPasses      VisitorPass[]
  storeOrders        StoreOrder[]
  emergencyAlerts    EmergencyAlert[]    @relation("EmergencyReporter")
  incidentReports    IncidentReport[]    @relation("IncidentReporter")
}

model Profile {
  id        String    @id @default(uuid())
  firstName String
  lastName  String
  avatarUrl String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  country   String?
  dob       DateTime?
  gender    String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id               String  @id @default(uuid())
  admissionNo      String  @unique
  rollNo           String?
  bloodGroup       String?
  emergencyContact String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Parent? @relation(fields: [parentId], references: [id])

  classes    StudentClass[]
  attendance Attendance[]

  feeInvoices FeeInvoice[]

  hostelRoomId String?
  hostelRoom   HostelRoom? @relation(fields: [hostelRoomId], references: [id])

  doubts       Doubt[]
  achievements Achievement[]
  badges       StudentBadge[]
  rewardPoints RewardPoint[]
  diaryEntries StudentDiaryEntry[]
  submissions  AssignmentSubmission[]
  examResults  ExamResult[]
}

model Teacher {
  id            String   @id @default(uuid())
  employeeId    String   @unique
  qualification String?
  joiningDate   DateTime @default(now())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  classes  Class[]
  subjects Subject[]

  taggedDoubts     Doubt[]
  diaryEntries     StudentDiaryEntry[]
  timetablePeriods TimetablePeriod[]
}

model Parent {
  id         String  @id @default(uuid())
  occupation String?
  income     Float?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  students Student[]
}

model Class {
  id      String @id @default(uuid())
  name    String // e.g., "10"
  section String // e.g., "A"

  teacherId    String?
  classTeacher Teacher? @relation(fields: [teacherId], references: [id])

  students StudentClass[]
  subjects Subject[]

  workspace        ClassWorkspace?
  boards           DiscussionBoard[]
  exams            Exam[]
  timetablePeriods TimetablePeriod[]
}

model StudentClass {
  studentId    String
  classId      String
  academicYear String

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@id([studentId, classId, academicYear])
}

model Subject {
  id   String @id @default(uuid())
  name String
  code String

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  teacherId        String?
  teacher          Teacher?          @relation(fields: [teacherId], references: [id])
  examResults      ExamResult[]
  timetablePeriods TimetablePeriod[]
}

model Attendance {
  id      String   @id @default(uuid())
  date    DateTime
  status  String // PRESENT, ABSENT, LATE, HALF_DAY
  remarks String?

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
}

// Phase 4: Operations

model FeeInvoice {
  id          String   @id @default(uuid())
  amount      Float
  dueDate     DateTime
  status      String // PENDING, PAID, OVERDUE
  description String

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  payments FeePayment[]
}

model FeePayment {
  id        String   @id @default(uuid())
  amount    Float
  date      DateTime @default(now())
  method    String // CASH, UPI, CARD, BANK_TRANSFER
  reference String?

  invoiceId String
  invoice   FeeInvoice @relation(fields: [invoiceId], references: [id])
}

model Book {
  id          String  @id @default(uuid())
  title       String
  author      String
  isbn        String? @unique
  totalCopies Int     @default(1)
  available   Int     @default(1)
  pdfUrl      String?

  issues BookIssue[]
}

model BookIssue {
  id         String    @id @default(uuid())
  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  fine       Float     @default(0)

  bookId String
  book   Book   @relation(fields: [bookId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model TransportRoute {
  id         String @id @default(uuid())
  name       String
  startPoint String
  endPoint   String

  vehicles Vehicle[]
}

model Vehicle {
  id       String @id @default(uuid())
  number   String @unique
  capacity Int

  routeId  String?
  route    TransportRoute? @relation(fields: [routeId], references: [id])
  driverId String?
  driver   User?           @relation(fields: [driverId], references: [id])
}

model HostelRoom {
  id         String @id @default(uuid())
  roomNumber String @unique
  capacity   Int
  occupied   Int    @default(0)

  students Student[]
}

// Phase 5: Communication

model Message {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id])

  read Boolean @default(false)
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  body      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  read Boolean @default(false)
}

// Phase 6 & 7: Settings & Analytics

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  details   String?
  createdAt DateTime @default(now())
}

// ==========================================
// ADVANCED LMS & COLLABORATION PLATFORM
// ==========================================

// Domain 1: LMS & Collaboration

model ClassWorkspace {
  id          String  @id @default(uuid())
  name        String
  description String?

  classId String @unique
  class   Class  @relation(fields: [classId], references: [id])

  posts       WorkspacePost[]
  assignments WorkspaceAssignment[]
}

model WorkspacePost {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  isPinned  Boolean  @default(false)

  workspaceId String
  workspace   ClassWorkspace @relation(fields: [workspaceId], references: [id])
  authorId    String
  author      User           @relation(fields: [authorId], references: [id])

  files WorkspaceFile[]
}

model WorkspaceFile {
  id       String @id @default(uuid())
  fileUrl  String
  fileName String

  postId String?
  post   WorkspacePost? @relation(fields: [postId], references: [id])
}

model WorkspaceAssignment {
  id            String   @id @default(uuid())
  title         String
  description   String
  dueDate       DateTime
  attachmentUrl String?
  createdAt     DateTime @default(now())

  workspaceId String
  workspace   ClassWorkspace @relation(fields: [workspaceId], references: [id])

  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id          String   @id @default(uuid())
  fileUrl     String
  submittedAt DateTime @default(now())
  grade       String?
  feedback    String?

  assignmentId String
  assignment   WorkspaceAssignment @relation(fields: [assignmentId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
}

model Doubt {
  id         String   @id @default(uuid())
  subject    String
  content    String
  isUrgent   Boolean  @default(false)
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  taggedTeacherId String?
  taggedTeacher   Teacher? @relation(fields: [taggedTeacherId], references: [id])

  replies DoubtReply[]
}

model DoubtReply {
  id         String   @id @default(uuid())
  content    String
  createdAt  DateTime @default(now())
  isAccepted Boolean  @default(false)

  doubtId  String
  doubt    Doubt  @relation(fields: [doubtId], references: [id])
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
}

model DiscussionBoard {
  id          String  @id @default(uuid())
  title       String
  description String?

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  threads DiscussionThread[]
}

model DiscussionThread {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())

  boardId  String
  board    DiscussionBoard @relation(fields: [boardId], references: [id])
  authorId String
  author   User            @relation(fields: [authorId], references: [id])

  replies ThreadReply[]
}

model ThreadReply {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  threadId String
  thread   DiscussionThread @relation(fields: [threadId], references: [id])
  authorId String
  author   User             @relation(fields: [authorId], references: [id])
}

// Domain 2: Student Performance & Engagement

model Achievement {
  id           String   @id @default(uuid())
  title        String
  category     String // ACADEMIC, SPORTS, ARTS, CLUB, VOLUNTEER
  description  String
  dateEarned   DateTime @default(now())
  academicYear String? // e.g. "2023-2024"

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model StudentBadge {
  id        String   @id @default(uuid())
  name      String
  iconUrl   String
  awardedAt DateTime @default(now())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model RewardPoint {
  id        String   @id @default(uuid())
  points    Int
  reason    String
  awardedAt DateTime @default(now())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model StudentDiaryEntry {
  id        String   @id @default(uuid())
  type      String // REMARK, APPRECIATION, SUGGESTION, DISCIPLINE
  content   String
  createdAt DateTime @default(now())

  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
}

// Domain 3: Parent Involvement & Feedback

model Survey {
  id          String   @id @default(uuid())
  title       String
  description String?
  createdAt   DateTime @default(now())

  questions SurveyQuestion[]
  responses SurveyResponse[]
}

model SurveyQuestion {
  id      String @id @default(uuid())
  text    String
  type    String // MULTIPLE_CHOICE, TEXT, RATING
  options String // Stored as JSON string for multiple choice

  surveyId String
  survey   Survey @relation(fields: [surveyId], references: [id])
}

model SurveyResponse {
  id          String   @id @default(uuid())
  answers     String // Stored as JSON string
  submittedAt DateTime @default(now())

  surveyId String
  survey   Survey  @relation(fields: [surveyId], references: [id])
  userId   String? // Optional for anonymous
  user     User?   @relation(fields: [userId], references: [id])
}

model Complaint {
  id          String   @id @default(uuid())
  title       String
  description String
  status      String // OPEN, IN_PROGRESS, RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String? // Optional for anonymous
  author   User?   @relation(fields: [authorId], references: [id])
}

model Publication {
  id        String   @id @default(uuid())
  title     String
  issueDate DateTime
  type      String // NEWSLETTER, MAGAZINE

  articles Article[]
}

model Article {
  id         String @id @default(uuid())
  title      String
  content    String
  authorName String

  publicationId String
  publication   Publication @relation(fields: [publicationId], references: [id])
}

// Domain 4: Extended Operations & Safety

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  imageUrl    String?

  registrations EventRegistration[]
}

model EventRegistration {
  id           String   @id @default(uuid())
  registeredAt DateTime @default(now())
  status       String // REGISTERED, ATTENDED

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])
  userId  String
  user    User   @relation(fields: [userId], references: [id])
}

model LostFoundItem {
  id           String   @id @default(uuid())
  type         String // LOST, FOUND
  itemName     String
  description  String
  status       String // REPORTED, CLAIMED, RETURNED
  dateReported DateTime @default(now())

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])
}

model VisitorPass {
  id          String    @id @default(uuid())
  visitorName String
  purpose     String
  checkIn     DateTime  @default(now())
  checkOut    DateTime?

  hostId String?
  host   User?   @relation(fields: [hostId], references: [id])
}

model StoreProduct {
  id    String @id @default(uuid())
  name  String
  price Float
  stock Int    @default(0)

  orders StoreOrder[]
}

model StoreOrder {
  id         String   @id @default(uuid())
  quantity   Int
  totalPrice Float
  orderDate  DateTime @default(now())
  status     String // PENDING, COMPLETED, CANCELLED

  productId String
  product   StoreProduct @relation(fields: [productId], references: [id])
  userId    String
  user      User         @relation(fields: [userId], references: [id])
}

model EmergencyAlert {
  id        String   @id @default(uuid())
  type      String // MEDICAL, FIRE, LOCKDOWN, OTHER
  message   String
  createdAt DateTime @default(now())
  status    String // ACTIVE, RESOLVED

  reportedBy String
  reporter   User   @relation("EmergencyReporter", fields: [reportedBy], references: [id])
}

model IncidentReport {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime @default(now())

  reportedBy String
  reporter   User   @relation("IncidentReporter", fields: [reportedBy], references: [id])
}

model SchoolDashboardCounter {
  id        String   @id @default(uuid())
  key       String   @unique
  label     String
  value     Int      @default(0)
  iconUrl   String?
  category  String?
  updatedAt DateTime @updatedAt
}

// Domain 5: Academics & Report Cards

model Exam {
  id           String   @id @default(uuid())
  title        String // e.g., "Term 1 Finals", "Midterms"
  date         DateTime
  academicYear String

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  results ExamResult[]
}

model ExamResult {
  id            String  @id @default(uuid())
  marksObtained Float
  maxMarks      Float
  remarks       String?

  examId String
  exam   Exam   @relation(fields: [examId], references: [id])

  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([examId, studentId, subjectId])
}

model TimetablePeriod {
  id        String @id @default(uuid())
  dayOfWeek Int // 1=Monday...5=Friday
  startTime String // e.g., "09:00"
  endTime   String // e.g., "09:45"

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([classId, dayOfWeek, startTime])
}
